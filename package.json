{
  "name": "try-astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev --host",
    "build": "astro build",
    "preview": "astro build && astro preview --host",
    "astro": "astro",
    "check": "eslint . && svelte-check"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-astro",
      "prettier-plugin-svelte",
      "prettier-plugin-tailwindcss",
      "prettier-plugin-multiline-arrays"
    ],
    "printWidth": 100,
    "overrides": [
      {
        "files": [
          "**/en.svelte.ts",
          "**/jp.svelte.ts",
          "**/jp/FlashcardSettingsJP.svelte",
          "**/kr.svelte.ts"
        ],
        "options": {
          "printWidth": 140
        }
      },
      {
        "files": [
          "**/locales/*/words-*.svelte.ts",
          "**/locales/*/letters.svelte.ts"
        ],
        "options": {
          "printWidth": 999
        }
      }
    ],
    "tailwindStylesheet": "./src/styles.css"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/svelte": "^8.1.0",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/icon-park-outline": "^1.2.4",
    "@iconify-json/icon-park-solid": "^1.2.4",
    "@iconify-json/ix": "^1.2.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.2.1",
    "astro-icon": "^1.1.5",
    "dayjs": "^1.11.20",
    "es-toolkit": "^1.46.1",
    "svelte": "^5.55.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@iconify/tailwind4": "^1.2.3",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-multiline-arrays": "4.1.7",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte-check": "^4.4.7",
    "typescript-eslint": "^8.59.1"
  }
}
