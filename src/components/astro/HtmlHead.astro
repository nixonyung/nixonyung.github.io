---
import favicon from "@/assets/favicon.svg";
import { getLocalizedMessage } from "@/i18n";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="color-scheme" content="light dark" />
<meta name="description" content="Nixon Yung's Blog" />
<meta name="google-site-verification" content="aMe-4fFPNYVsoK3TKSMGpH1Wb2BrBCVWpYbrN7rJoMA" />
<link rel="icon" type="image/svg+xml" href={favicon.src} />
<link rel="sitemap" href="/sitemap-index.xml" />
<title>
  {(title ? `${title} — ` : "") + getLocalizedMessage("siteTitle", Astro.currentLocale)}
</title>

<Font cssVariable="--font-recursive" />
<Font cssVariable="--font-noto-sans-hk" />
<Font cssVariable="--font-lxgw-wenkai-tc" />

<ClientRouter />
